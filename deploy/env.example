OSB_PLUS_APP_ROLE=all
OSB_PLUS_PUBLIC_BASE_URL=http://localhost:8080
OSB_PLUS_DATABASE_URL=postgresql+asyncpg://opensandbox_plus:opensandbox_plus@postgres:5432/opensandbox_plus
OSB_PLUS_WAIT_FOR_DATABASE=true
OSB_PLUS_DB_WAIT_TIMEOUT_SECONDS=90
OSB_PLUS_RUN_MIGRATIONS=true
OSB_PLUS_ALEMBIC_INI=/app/server/alembic.ini
OSB_PLUS_REDIS_URL=redis://redis:6379/0
OSB_PLUS_CONSOLE_STATIC_DIR=/app/static/console
OSB_PLUS_CASDOOR_ISSUER=http://localhost:8000
OSB_PLUS_CASDOOR_AUDIENCE=osb-console
OSB_PLUS_CASDOOR_DISCOVERY_URL=http://casdoor:8000/.well-known/openid-configuration
OSB_PLUS_CASDOOR_JWKS_URL=http://casdoor:8000/.well-known/jwks
OSB_PLUS_CASDOOR_ADMIN_CLIENT_ID=osb-plus-admin
OSB_PLUS_CASDOOR_ADMIN_CLIENT_SECRET=change-me
VITE_CASDOOR_AUTHORITY=http://localhost:8000
VITE_CASDOOR_CLIENT_ID=osb-console
VITE_CASDOOR_REDIRECT_URI=http://localhost:8080/
VITE_CASDOOR_POST_LOGOUT_REDIRECT_URI=http://localhost:8080/
VITE_CASDOOR_SCOPE=openid profile email
OSB_PLUS_CREDENTIAL_SECRET_PEPPER=change-me-credential-pepper
OSB_PLUS_CREDENTIAL_DEFAULT_EXPIRES_DAYS=180
OSB_PLUS_CREDENTIAL_MAX_EXPIRES_DAYS=180
OSB_PLUS_CREDENTIAL_MAX_KEYS_PER_USER=10
OSB_PLUS_OPENSANDBOX_DEFAULT_BACKEND_BASE_URL=http://opensandbox:8090
OSB_PLUS_OPENSANDBOX_INTERNAL_API_KEY=change-me-internal-opensandbox-key
